generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders          Order[]
  massageBookings MassageBooking[]

  @@map("users")
}

model ProductCategory {
  id             String   @id @default(cuid())
  slug           String   @unique
  name_fi        String
  name_en        String
  description_fi String?
  description_en String?
  imageUrl       String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  products Product[]

  @@map("product_categories")
}

model Product {
  id             String   @id @default(cuid())
  slug           String   @unique
  name_fi        String
  name_en        String
  description_fi String
  description_en String
  priceSmall     Decimal  @db.Decimal(10, 2)
  priceLarge     Decimal? @db.Decimal(10, 2)
  imageUrl       String
  imageUrls      String[] @default([])
  categoryId     String
  inStock        Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  isFuneral      Boolean  @default(false)
  isWedding      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category   ProductCategory @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("products")
}

model DeliveryZone {
  id           String  @id @default(cuid())
  city         String
  freeRadiusKm Int
  priceWithin  Decimal @default(0) @db.Decimal(10, 2)
  priceOutside Decimal @db.Decimal(10, 2)
  sameDayCity  Boolean @default(false)
  isActive     Boolean @default(true)

  orders Order[]

  @@map("delivery_zones")
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique @default(cuid())
  userId           String?
  status           OrderStatus   @default(PENDING)
  subtotal         Decimal       @db.Decimal(10, 2)
  deliveryFee      Decimal       @default(0) @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  deliveryZoneId   String?
  deliveryType     DeliveryType
  deliveryAddress  String?
  deliveryCity     String?
  deliveryNote     String?
  scheduledAt      DateTime?
  customerName     String
  customerEmail    String
  customerPhone    String
  paymentMethod    String
  paymentStatus    PaymentStatus @default(PENDING)
  stripeSessionId  String?
  giftCardCode     String?
  giftCardDiscount Decimal?      @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user         User?         @relation(fields: [userId], references: [id])
  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  items        OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String      @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  size      ProductSize
  price     Decimal     @db.Decimal(10, 2)
  name_fi   String
  name_en   String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model GiftCard {
  id             String         @id @default(cuid())
  code           String         @unique @default(cuid())
  amount         Decimal        @db.Decimal(10, 2)
  balance        Decimal        @db.Decimal(10, 2)
  status         GiftCardStatus @default(ACTIVE)
  purchaserName  String
  purchaserEmail String
  recipientName  String?
  recipientEmail String?
  message        String?
  expiresAt      DateTime
  createdAt      DateTime       @default(now())

  @@map("gift_cards")
}

model MassageBooking {
  id           String        @id @default(cuid())
  userId       String?
  name         String
  email        String
  phone        String
  service      String
  servicePrice Decimal       @db.Decimal(10, 2)
  date         DateTime
  time         String
  duration     Int
  status       BookingStatus @default(PENDING)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@map("massage_bookings")
}

model PaymentMethod {
  id             String  @id @default(cuid())
  name           String
  provider       String
  description_fi String?
  description_en String?
  isActive       Boolean @default(true)
  sortOrder      Int     @default(0)

  @@map("payment_methods")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeliveryType {
  HOME
  SCHOOL
  CITY_CENTER
  PICKUP
}

enum ProductSize {
  SMALL
  LARGE
}

enum GiftCardStatus {
  ACTIVE
  USED
  EXPIRED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
